# Copy this file to `.env` at the project root (same folder as `Assets/`).
# RevenueCat public SDK keys from: https://app.revenuecat.com → Project settings → API keys
#
# After editing `.env`, open Unity and run menu:
#   Snowman Run → Revenue Cat → Sync keys from .env
# That writes `Assets/StreamingAssets/revenuecat_keys.json` (gitignored) for device builds.
#
# Unity Editor cannot show RevenueCat paywalls; test on an iOS or Android device.

REVENUECAT_IOS_PUBLIC_API_KEY=
REVENUECAT_ANDROID_PUBLIC_API_KEY=
